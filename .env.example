# ── HubSpot Private App Token (required) ─────────────────────────────────────
# Create at: HubSpot → Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.read, crm.objects.contacts.write,
#                crm.objects.companies.read, crm.schemas.contacts.read,
#                crm.schemas.contacts.write
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Apollo.io API Key (required for lead enrichment) ─────────────────────────
# Get it from: Apollo → Settings → Integrations → API Keys
# This enriches leads with employee count, job title, country, industry, etc.
APOLLO_API_KEY=your-apollo-api-key-here

# ── Tech stack field name in HubSpot (optional) ───────────────────────────────
# Default is "technologies". Change to match your custom property name.
# TECH_STACK_FIELD=technologies

# ── HubSpot team field name (optional) ────────────────────────────────────────
# The internal property name for your custom "HUBSPOT TEAM" contact field.
# If omitted, auto-discovered by looking up properties with label "HUBSPOT TEAM".
# HUBSPOT_TEAM_FIELD=hubspot_team

# ── Login credentials (optional, defaults shown below) ───────────────────────
# IMPORTANT: Change these before deploying to production!
# AUTH_USERNAME=CFMARKETING
# AUTH_PASSWORD=CloudFuze@2026

# ── Session secret (optional, MUST change in production) ─────────────────────
# SESSION_SECRET=change-me-to-a-long-random-string

# ── HubSpot "select country" field name (optional) ───────────────────────────
# If you have a custom "select_country" contact property in HubSpot, set it here.
# SELECT_COUNTRY_FIELD=select_country

# ── Server port (optional, defaults to 3000) ──────────────────────────────────
# PORT=3000
